{
  "name": "brand-ops",
  "version": "0.1.0",
  "description": "Brand Operations - AI-Orchestrated Creative Asset Management",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src --ext .ts,.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "sync:ide": "node .aiox-core/infrastructure/scripts/ide-sync/index.js",
    "sync:ide:check": "node .aiox-core/infrastructure/scripts/ide-sync/index.js --check",
    "sync:skills:codex": "node .aiox-core/infrastructure/scripts/codex-skills-sync/index.js",
    "validate:structure": "node .aiox-core/infrastructure/scripts/aiox-validator.js",
    "validate:agents": "node .aiox-core/infrastructure/scripts/validate-agents.js"
  },
  "keywords": [
    "ai",
    "orchestration",
    "brand-ops",
    "creative-assets"
  ],
  "author": "Synkra",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "@reduxjs/toolkit": "^2.11.2",
    "chokidar": "^5.0.0",
    "next": "^16.2.2",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-redux": "^9.2.0",
    "sharp": "^0.34.5",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "prisma": "^5.9.1",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0"
  }
}
