{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": "../../",
    "paths": {
      "@/*": ["src/*"],
      "@pages/*": ["pages/*"],
      "@brand-ops/ui": ["packages/ui/index.ts"],
      "@brand-ops/ui/*": ["packages/ui/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"]
}
