# ============================================================================
# BRAND-OPS ENVIRONMENT VARIABLES CONFIGURATION
# ============================================================================
# Copy this file to .env.local and update values for your environment
# Required variables marked with [REQUIRED]
# Optional variables have sensible defaults [OPTIONAL]
# ============================================================================

# DATABASE CONFIGURATION
# ============================================================================
# Database connection for Prisma ORM

DATABASE_URL="file:./data/brand-ops.db"
# Type: String [REQUIRED]
# Description: Database connection URL for Prisma ORM
# Format: file:./path/to/database.db (SQLite)
# Used by: Prisma migrations, database queries
# Note: For SQLite, uses relative path from project root

# APPLICATION ENVIRONMENT
# ============================================================================
# Runtime environment and behavior

NODE_ENV="development"
# Type: String [REQUIRED]
# Valid values: development | production | test
# Default: development
# Description: Controls logging level, optimization, and feature flags
# - development: Verbose logging, source maps, error details
# - production: Minimal logging, optimized build
# - test: Jest testing environment, mocked services

# NEXT.JS PUBLIC API CONFIGURATION
# ============================================================================
# Public API endpoint (visible in client-side code)

NEXT_PUBLIC_API_URL="http://localhost:3000/api"
# Type: String [REQUIRED]
# Description: Base URL for API endpoints used by client-side code
# Format: http(s)://host[:port]/api
# Examples:
#   Local: http://localhost:3000/api
#   Production: https://api.yourdomain.com/api
# Used by: Frontend API calls, fetch requests

# LOGGING CONFIGURATION
# ============================================================================
# Application logging level

LOG_LEVEL="debug"
# Type: String [OPTIONAL]
# Valid values: debug | info | warn | error
# Default: info
# Description: Controls console output verbosity
# - debug: All messages including development details
# - info: Information, warnings, and errors only
# - warn: Warnings and errors only
# - error: Errors only
# Used by: Logger utility functions throughout app

# FILE UPLOAD CONFIGURATION
# ============================================================================
# Controls file upload validation and constraints

MAX_FILE_SIZE_MB="50"
# Type: Number [REQUIRED]
# Default: 50
# Description: Maximum file size allowed for uploads in megabytes
# Validation: Must be a positive number
# Purpose: Prevents storage abuse and DoS attacks via oversized files
# HTTP response: 413 Payload Too Large if exceeded
# Used by: Story 10.2 file validation utility

ALLOWED_FILE_TYPES="jpg,jpeg,png,gif,mp4,mov,webm,psd,ai"
# Type: String [REQUIRED]
# Format: Comma-separated list of file extensions (lowercase, no spaces)
# Default: jpg,jpeg,png,gif,mp4,mov,webm,psd,ai
# Description: Whitelist of allowed file types for upload
# Valid examples:
#   Images only: jpg,jpeg,png,gif
#   Video only: mp4,mov,webm
#   Design files: psd,ai,sketch
# Security: Server validates both extension AND MIME type to prevent spoofing
# HTTP response: 400 Bad Request if file type not in whitelist
# Used by: Story 10.2 file validation utility

# STORAGE CONFIGURATION (OPTIONAL)
# ============================================================================
# Local storage location for uploaded assets

# STORAGE_ROOT="./data/storage"
# Type: String [OPTIONAL]
# Default: ./data/storage (if not set, uses ./data/uploads)
# Description: Root directory path for storing uploaded files
# Format: Relative path from project root
# Examples:
#   Local storage: ./data/storage
#   External mount: /mnt/storage
# Note: Directory must be writable by the application process
# Security: Should be outside public/ directory to prevent direct access

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 2. Update values for your environment:
#    - Ensure DATABASE_URL points to correct database
#    - Set NEXT_PUBLIC_API_URL to your API endpoint
#    - Adjust MAX_FILE_SIZE_MB and ALLOWED_FILE_TYPES as needed
#
# 3. For production:
#    - Never commit .env.local to version control
#    - Use secure environment variable management
#    - Validate all values before deployment
#
# ============================================================================
