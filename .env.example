# Database Configuration
DATABASE_URL="file:./data/brand-ops.db"

# Next.js Public API Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Logging Configuration
LOG_LEVEL="debug"

# Optional local storage root for uploaded assets
# STORAGE_ROOT="./data/storage"

# File Upload Configuration
MAX_FILE_SIZE_MB="50"
# Maximum file size in megabytes allowed for uploads
# Prevents storage abuse and DoS attacks

ALLOWED_FILE_TYPES="jpg,jpeg,png,gif,mp4,mov,webm,psd,ai"
# Comma-separated list of allowed file types (extensions)
# Server validates both extension and MIME type for security

# Environment
NODE_ENV="development"
